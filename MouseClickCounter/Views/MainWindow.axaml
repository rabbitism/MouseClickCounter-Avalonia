<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MouseClickCounter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        x:Class="MouseClickCounter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Mouse Click Counter"
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <TextBlock Text="Mouse Click Counter"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding ClickCount}"
                   FontSize="48"
                   HorizontalAlignment="Center" />
        <Button Content="Click Me!"
                Command="{Binding IncrementClickCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
        <Button Content="Reset"
                Command="{Binding ResetClickCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
    </StackPanel>

</Window>
