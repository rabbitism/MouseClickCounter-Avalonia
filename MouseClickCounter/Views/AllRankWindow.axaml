<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MouseClickCounter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="MouseClickCounter.Views.AllRankWindow"
        x:DataType="vm:AllRankViewModel"
        Title="全国省份排行榜"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:AllRankViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- 顶部工具栏 -->
        <StackPanel DockPanel.Dock="Top"
                   Orientation="Horizontal"
                   Margin="15"
                   Spacing="15">
            <Button Content="刷新数据"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding !IsLoading}" />
            <TextBlock Text="{Binding StatsText}"
                      VerticalAlignment="Center"
                      FontSize="12"
                      Foreground="Gray" />
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid DockPanel.Dock="Top"
                 ItemsSource="{Binding Rankings}"
                 IsReadOnly="True"
                 AutoGenerateColumns="False"
                 GridLinesVisibility="Horizontal"
                 Margin="15,0,15,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="排名" Binding="{Binding Rank}" Width="80" />
                <DataGridTextColumn Header="省份" Binding="{Binding Province}" Width="150" />
                <DataGridTextColumn Header="设备数" Binding="{Binding DeviceCount}" Width="120" />
                <DataGridTextColumn Header="总点击" Binding="{Binding TotalClicks}" Width="150" />
                <DataGridTextColumn Header="左键点击" Binding="{Binding TotalLeftClicks}" Width="150" />
                <DataGridTextColumn Header="右键点击" Binding="{Binding TotalRightClicks}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部按钮 -->
        <Button DockPanel.Dock="Bottom"
                Content="关闭"
                Name="CloseButton"
                Width="100"
                Height="35"
                Margin="15"
                HorizontalAlignment="Right" />
    </DockPanel>

</Window>
